# /etc/companion/companion.env
# PartyBox Companion — operator configuration
#
# This file is read by systemd as an EnvironmentFile. Uncomment and set values
# to override defaults. The Portal (http://partybox) is the primary configuration
# interface — most settings are managed there and persisted to
# /var/lib/companion/config.json. Only machine-level or deployment-specific
# settings belong here.
#
# After editing, restart the service:
#   sudo systemctl restart companion

# Bluetooth Classic (A2DP) MAC address of the speaker.
# Required for the appliance to manage the audio connection automatically.
# Find the address with:  bluetoothctl devices
#
# COMPANION_AUDIO__SINK_ADDRESS=50:1B:6A:14:FD:1D

# HTTP port (default: 8080).
# The production appliance exposes port 80; the mechanism is set at image build time.
# Enable once the port 80 binding strategy has been chosen (M14).
#
# COMPANION_PORT=80

# Spotify Connect device name shown in Spotify clients.
# Can also be changed from the Portal Settings panel without editing this file.
#
# COMPANION_SPOTIFY__CONNECT_NAME=PartyBox

# Log level: DEBUG, INFO, WARNING, ERROR  (default: INFO)
#
# COMPANION_LOG_LEVEL=INFO

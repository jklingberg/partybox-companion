# Raspberry Pi OS Lite ARM64 base image
#
# All three values must be updated together when upgrading the base image.
# Find releases at:
#   https://downloads.raspberrypi.com/raspios_lite_arm64/images/
#
# After changing PI_OS_URL, push a pre-release tag (e.g. v1.0.0-rc.1) to
# trigger a test build before tagging a final release.

PI_OS_VERSION="2024-11-19"
PI_OS_NAME="Raspberry Pi OS Bookworm Lite ARM64"
PI_OS_URL="https://downloads.raspberrypi.com/raspios_lite_arm64/images/raspios_lite_arm64-2024-11-19/2024-11-19-raspios-bookworm-arm64-lite.img.xz"
